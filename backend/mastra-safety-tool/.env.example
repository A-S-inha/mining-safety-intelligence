# Copy to ".env" in this directory (mastra-safety-tool). Never commit ".env".
#
# Mastra CLI (`mastra dev` / `mastra start`): loads ONE env file — the first that exists in this order:
#   .env.development  →  .env.local  →  .env
# If `.env.development` exists but is empty of API keys, your real keys in `.env` are ignored.
# Merge secrets into the winning file, or delete/rename the empty higher-priority file.

# --- MUE agents: NVIDIA NIM (OpenAI-compatible) — required ---
# Create a key at https://build.nvidia.com/ or your NGC / enterprise NIM docs.
NVIDIA_API_KEY=

# JSON "model" for integrate.api.nvidia.com (official infer API uses meta/…, not nvidia/meta/…)
# NVIDIA_NIM_MODEL=meta/llama-3.3-70b-instruct
# Other NIM deployments only: set the model string your server expects, e.g. catalog-style ids.
#
# If you see HTTP 504 / "Gateway Timeout" with nvcf-status: errored — that is NVIDIA's gateway (cold start / load).
# The planner step retries a few times; try again or a smaller model / region per NVIDIA docs.

# Base URL including /v1 (local container example: http://127.0.0.1:8000/v1)
# NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1

# Alias for NVIDIA_API_KEY if you prefer
# NIM_API_KEY=

# --- Optional: Weather sample agent still uses Anthropic in code ---
# ANTHROPIC_API_KEY=

# --- Optional: Mastra Cloud tracing ---
# MASTRA_CLOUD_ACCESS_TOKEN=

# HTTP request timeout for the Mastra Node server (ms). Long MUE runs need this. Default 600000 (10 min).
# MASTRA_SERVER_TIMEOUT_MS=

# --- Optional: logging (see src/mastra/index.ts, src/mastra/lib/log-paths.ts) ---
# Absolute path, or path relative to the shell cwd when you start the server
# MASTRA_LOG_DIR=

# debug | info | warn | error
# MASTRA_LOG_LEVEL=info

# Set to "false" for raw JSON on the console (e.g. log aggregators)
# MASTRA_LOG_PRETTY=true

# --- MSHA pipe-delimited data (default: backend/data/accidents as file or backend/data/accidents/Accidents.txt; legacy: backend/data/Accidents.txt) ---
# MSHA_ACCIDENTS_FILE=         — optional absolute path, or relative to server cwd
#
# Smaller file for faster, reproducible testing (also builds *.labels.json for npm run eval:mue):
#   npm run extract:msha-sample -- --max-lines 4000
# Path is relative to mastra-safety-tool/ (NOT process.cwd). Use .. to reach backend/data:
# MSHA_ACCIDENTS_FILE=../data/accidents/Accidents.sample.txt
#
# Correlation: mue-runs.jsonl includes workflowRunId; per-step traces in logs/mue-workflow-steps.jsonl (same id).
#
# After a sample-backed run: npm run eval:mue → append mue-eval.jsonl + write logs/eval-reports/eval-<timestamp>.{json,md}
# Keyword ideas from the sample file: npm run suggest:sample-keywords → data/accidents/Accidents.sample.keyword-hints.{md,json}
#
# Automated Part-1 benchmark (needs mastra dev running): npm run benchmark:mue
# Optional: MUE_BENCHMARK_URL=http://127.0.0.1:4111/find-mues
# Logs: backend/logs/benchmark-reports/benchmark-<ts>.{json,md} + mue-benchmark-runs.jsonl
# MSHA_MEMORY_CACHE=serious  (default) — one disk read, keep serious/fatal rows only; best RAM/size tradeoff for MUE finder
# MSHA_MEMORY_CACHE=full       — cache every row (~hundreds of MB for full MSHA file); use if agents often call with includeAllSeverities
# MSHA_MEMORY_CACHE=off        — stream from disk every query (lowest RAM)
# Legacy: MSHA_MEMORY_INDEX=false same as MSHA_MEMORY_CACHE=off
#
# Sample = up to maxRecords rows from matches. Default: fatalities first (then file order within each band), so the LLM sees more deaths than "first rows in file".
# MSHA_SAMPLE_FATALITY_FIRST=false  — no severity reorder; sample = match order (token) or BM25 score order
# When true (default): token mode sorts the match list by DEGREE_INJURY_CD (01 fatality first, then 02…07) before maxRecords slice. BM25 mode unchanged.
#
# Retrieval: `token` (default) = every query word must appear as a substring in narrative/classification/etc.
# `bm25` = rank mine+severity-filtered rows by Okapi BM25 on the same text (synonym-friendly via term overlap; needs in-memory cache).
# MSHA_RETRIEVAL_MODE=token
# MSHA_RETRIEVAL_MODE=bm25
