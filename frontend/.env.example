# Copy to ".env" or ".env.local" in this directory (frontend). Never commit secrets.

# Dev: Vite proxies /find-mues and /find-controls to this URL (Mastra dev server).
# Override if Mastra runs on another host/port.
VITE_MASTRA_PROXY_TARGET=http://localhost:4111

# Production or cross-origin: base URL for API calls (no trailing slash).
# When set, the app uses fetch(`${VITE_API_BASE}/find-mues`, ...) instead of same-origin /find-mues.
# Leave empty in dev to use the Vite proxy.
# VITE_API_BASE=http://localhost:4111
